*.elf
*.bin
*.hex
*.map
*.list

# Bỏ qua file cấu hình cá nhân của CubeIDE / Eclipse
.settings/
.local_settings/
*.launch

# Bỏ qua các file log và lịch sử biên dịch
*.log
*.su

# Thư mục tạm thời của hệ điều hành
.DS_Store
Thumbs.db